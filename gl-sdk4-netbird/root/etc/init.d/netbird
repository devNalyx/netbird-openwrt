#!/bin/sh /etc/rc.common
# NetBird procd init — GL.iNet GL-MT3000 (OpenWrt 21.02)
# procd owns the daemon: auto-start at boot, auto-respawn on crash.
# Config lives in /etc/netbird/ (persistent overlay FS, not tmpfs).

USE_PROCD=1
START=90
STOP=10

start_service() {
    local MGMT
    MGMT=$(uci get netbird.@connection[0].management_url 2>/dev/null \
           || echo "https://your-netbird-server.example.com:443")

    # /var -> /tmp on OpenWrt: /var/lib is tmpfs, wiped on every reboot.
    # Symlink it to /etc/netbird (overlay FS) so the config and WireGuard keys survive.
    mkdir -p /etc/netbird /var/log/netbird
    mkdir -p /var/lib
    if [ ! -L /var/lib/netbird ]; then
        rm -rf /var/lib/netbird 2>/dev/null
        ln -s /etc/netbird /var/lib/netbird
    fi

    # Kill any stale daemon before procd registers its new PID.
    # Without this, a leftover process from a previous crash holds wt0/iptables.
    # NOTE: no `pkill` applet on this BusyBox build — it silently no-ops rather
    # than failing, which is exactly what let a "killed" stale daemon keep
    # running alongside the new procd-managed one. pgrep/killall are present.
    killall -q netbird 2>/dev/null; sleep 1
    rm -f /var/run/netbird.sock

    procd_open_instance
    procd_set_param command /usr/bin/netbird service run \
        --log-file /var/log/netbird/client.log \
        --log-level info
    procd_set_param respawn
    procd_set_param stdout 0
    procd_set_param stderr 0
    procd_close_instance

    # --disable-client-routes is mandatory on a router: prevents any peer's
    # 0.0.0.0/0 exit-node advertisement from overwriting the WAN default gateway.
    # Run in background — procd returns immediately from start_service.
    local mgmt="$MGMT"
    (
        i=0
        while [ ! -S /var/run/netbird.sock ] && [ $i -lt 30 ]; do
            sleep 1; i=$((i+1))
        done
        [ -S /var/run/netbird.sock ] && \
            /usr/bin/netbird up \
                --management-url "$mgmt" \
                --disable-client-routes >/dev/null 2>&1
    ) &
}

stop_service() {
    /usr/bin/netbird down >/dev/null 2>&1 || true
    killall -q netbird 2>/dev/null || true
    rm -f /var/run/netbird.sock
}
