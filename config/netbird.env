# NetBird enrollment configuration
# Source this file or export variables before running 'netbird up'.
#
# Usage:
#   source config/netbird.env
#   netbird up \
#     --management-url "$NETBIRD_MGMT_URL" \
#     --setup-key "$NETBIRD_SETUP_KEY" \
#     --disable-client-routes

# Your self-hosted NetBird management server (must include explicit port)
NETBIRD_MGMT_URL="https://your-netbird-server.example.com:443"

# Reusable setup key — get from: Dashboard → Setup Keys → Create (Reusable type)
NETBIRD_SETUP_KEY="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
